---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Kerehama Andrews — Home',
  description = 'Year 11 student, high-performance sport devotee, and Tauranga City Basketball referee.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body>
    <nav>
      <a href="/" class="brand">kerehama.nz</a>
      <span class="status">online</span>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      Built and updated by Miles · Powered by Astro · {new Date().getFullYear()}
    </footer>
  </body>
</html>
