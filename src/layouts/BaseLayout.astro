---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Kerehama Andrews — Home',
  description = 'Year 11 student, high-performance sport devotee, and Tauranga City Basketball referee.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body>
    <nav>
      <a href="/" class="brand">kerehama.nz</a>
      <div class="starmap-wrapper">
        <button class="starmap-toggle" aria-expanded="false" aria-controls="starmap-panel">Map</button>
        <div class="starmap" id="starmap-panel" aria-label="Site map">
          <svg viewBox="0 0 260 120" xmlns="http://www.w3.org/2000/svg">
            <!-- lines from center to satellites -->
            <line x1="130" y1="60" x2="40" y2="28" class="starmap-line" />
            <line x1="130" y1="60" x2="50" y2="95" class="starmap-line" />
            <line x1="130" y1="60" x2="220" y2="25" class="starmap-line" />
            <line x1="130" y1="60" x2="215" y2="92" class="starmap-line" />

            <!-- satellite dots -->
            <a href="https://portfolio.kerehama.nz" target="_blank" rel="noopener">
              <circle cx="40" cy="28" r="6" class="starmap-dot" />
              <text x="40" y="8" class="starmap-label">portfolio</text>
            </a>
            <a href="https://lab.kerehama.nz" target="_blank" rel="noopener">
              <circle cx="50" cy="95" r="6" class="starmap-dot" />
              <text x="50" y="116" class="starmap-label">lab</text>
            </a>
            <a href="https://notes.kerehama.nz" target="_blank" rel="noopener">
              <circle cx="220" cy="25" r="6" class="starmap-dot" />
              <text x="220" y="6" class="starmap-label">notes</text>
            </a>
            <a href="#connect">
              <circle cx="215" cy="92" r="6" class="starmap-dot" />
              <text x="215" y="114" class="starmap-label">connect</text>
            </a>

            <!-- center dot (home) -->
            <a href="/">
              <circle cx="130" cy="60" r="8" class="starmap-dot starmap-home" />
              <text x="130" y="42" class="starmap-label starmap-label-home">kerehama.nz</text>
            </a>
          </svg>
        </div>
      </div>
    </nav>

    <script>
      const btn = document.querySelector('.starmap-toggle');
      const panel = document.getElementById('starmap-panel');
      btn?.addEventListener('click', () => {
        const open = panel.classList.toggle('open');
        btn.setAttribute('aria-expanded', String(open));
        btn.textContent = open ? '✕' : 'Map';
      });
      document.addEventListener('click', (e) => {
        if (!e.target.closest('.starmap-wrapper')) {
          panel?.classList.remove('open');
          btn?.setAttribute('aria-expanded', 'false');
          if (btn) btn.textContent = 'Map';
        }
      });
    </script>

    <main>
      <slot />
    </main>

    <footer class="mt-16 px-6 pb-10 pt-0 sm:px-10">
      <div class="rounded-[28px] border border-white/10 bg-gradient-to-br from-[#120b07]/95 via-[#050a08]/95 to-[#010101] px-6 py-10 shadow-koru sm:px-10">
        <div class="flex flex-col gap-8 lg:flex-row lg:items-start lg:justify-between">
          <div class="space-y-3 text-amber-50/80">
            <p class="text-xs font-semibold uppercase tracking-[0.45em] text-amber-200/70">kerehama.nz</p>
            <h3 class="text-2xl font-semibold text-white">Sport · Tech · Kōrero</h3>
            <p class="text-sm text-amber-50/70">Placeholder footer copy keeping the kaupapa grounded while the full site ships.</p>
          </div>
          <div class="grid gap-6 text-sm text-amber-50/80 sm:grid-cols-2 lg:grid-cols-3">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.4em] text-amber-200/70">Navigate</p>
              <ul class="mt-3 space-y-2 text-amber-50/70">
                <li><a href="#hero" class="transition hover:text-white">Hero</a></li>
                <li><a href="#portfolio" class="transition hover:text-white">Mahi</a></li>
                <li><a href="#spaces" class="transition hover:text-white">Spaces</a></li>
                <li><a href="#connect" class="transition hover:text-white">Connect</a></li>
              </ul>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.4em] text-amber-200/70">Links</p>
              <ul class="mt-3 space-y-2 text-amber-50/70">
                <li><a href="https://portfolio.kerehama.nz" target="_blank" rel="noopener noreferrer" class="transition hover:text-white">Portfolio</a></li>
                <li><a href="https://lab.kerehama.nz" target="_blank" rel="noopener noreferrer" class="transition hover:text-white">Lab</a></li>
                <li><a href="https://notes.kerehama.nz" target="_blank" rel="noopener noreferrer" class="transition hover:text-white">Notes</a></li>
                <li><a href="mailto:kerehama@andrewstribe.co.nz" class="transition hover:text-white">Email</a></li>
              </ul>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.4em] text-amber-200/70">Social</p>
              <ul class="mt-3 space-y-2 text-amber-50/70">
                <li><a href="https://www.instagram.com/kerehamaaa" target="_blank" rel="noopener noreferrer" class="transition hover:text-white">Instagram</a></li>
                <li><a href="https://www.tiktok.com/@itskerehama" target="_blank" rel="noopener noreferrer" class="transition hover:text-white">TikTok</a></li>
                <li><a href="#contact-cta" class="transition hover:text-white">Contact Form</a></li>
                <li><a href="#" class="transition hover:text-white">Placeholder</a></li>
              </ul>
            </div>
          </div>
        </div>
        <div class="mt-10 flex flex-col gap-2 border-t border-white/10 pt-6 text-xs uppercase tracking-[0.4em] text-amber-100/70 sm:flex-row sm:items-center sm:justify-between">
          <p>© {new Date().getFullYear()} Kerehama Andrews — All rights reserved</p>
          <p class="text-amber-200">Designed by Miles</p>
          <a href="#hero" class="text-amber-100/70 transition hover:text-white">Back to top</a>
        </div>
      </div>
    </footer>
  </body>
</html>
